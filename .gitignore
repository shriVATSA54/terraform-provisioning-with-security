# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan
plan.out

# CLI configuration files
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Dependency lock file (choose based on team policy)
# Ignore:
# .terraform.lock.hcl

# OR (Recommended) Commit it:
# !.terraform.lock.hcl

# Checkov output
checkov-report.json
checkov-report.xml

# Trivy output
trivy-report.json
trivy-report.txt

# VS Code
.vscode/

# IntelliJ
.idea/

# macOS
.DS_Store

# Linux
*.swp